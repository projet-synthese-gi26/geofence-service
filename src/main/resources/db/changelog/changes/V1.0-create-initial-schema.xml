    <!-- ================================================================ -->
    <!-- 7. TABLE : vehicle                                                -->
    <!--    Entité : Vehicle.java (@Table sans name → "vehicle")          -->
    <!-- ================================================================ -->

    <changeSet id="v1.0-create-vehicle" author="geofence-service">
